rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmail() {
      return signedIn() && request.auth.token.email == "admin@gmail.com";
    }

    function isAdmin() {
      return adminEmail()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isTrainer() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "trainer";
    }

    function trainerCanManageUser() {
      return isTrainer()
        && ("trainerIds" in resource.data)
        && request.auth.uid in resource.data.trainerIds;
    }

    function keepsExistingRole() {
      return !("role" in resource.data)
        || request.resource.data.role == resource.data.role;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin() || trainerCanManageUser());
      allow create: if signedIn()
        && request.auth.uid == userId
        && (
          !("role" in request.resource.data)
          || request.resource.data.role in ["user", "student", "trainer"]
          || (adminEmail() && request.resource.data.role == "admin")
        );
      allow update: if signedIn()
        && (
          isAdmin()
          || (
            trainerCanManageUser()
            && keepsExistingRole()
          )
          || (
            request.auth.uid == userId
            && keepsExistingRole()
          )
        );
      allow delete: if isAdmin();
    }

    match /routines/{routineId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (
          isTrainer()
          && request.resource.data.ownerTrainerId == request.auth.uid
        );
      allow update: if isAdmin()
        || (
          isTrainer()
          && resource.data.ownerTrainerId == request.auth.uid
          && request.resource.data.ownerTrainerId == request.auth.uid
        );
      allow delete: if isAdmin()
        || (
          isTrainer()
          && resource.data.ownerTrainerId == request.auth.uid
        );
    }

    match /trainerInvitations/{inviteId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || isTrainer()
          || resource.data.trainerId == request.auth.uid
          || resource.data.studentEmail == request.auth.token.email
        );
      allow create: if isTrainer()
        && request.resource.data.trainerId == request.auth.uid
        && request.resource.data.trainerEmail == request.auth.token.email
        && request.resource.data.status == "pending";
      allow update: if signedIn()
        && (
          isAdmin()
          || resource.data.trainerId == request.auth.uid
          || resource.data.studentEmail == request.auth.token.email
        );
      allow delete: if isAdmin()
        || (isTrainer() && resource.data.trainerId == request.auth.uid);
    }
  }
}
